# =============================================================================
# ComfyUI MCP Server Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# All variables are optional - defaults are shown below.

# ComfyUI server URL (include port, no trailing slash)
# Default: http://127.0.0.1:8188
COMFYUI_URL=http://127.0.0.1:8188

# Directory where saved workflows are persisted to disk
# Default: ./workflows (relative to working directory)
WORKFLOW_DIR=./workflows

# ComfyUI output directory for direct file access (optional)
# Only needed if you want the MCP server to access output files directly
# OUTPUT_DIR=/path/to/ComfyUI/output

# Default timeout for job completion polling (in seconds)
# Default: 300 (5 minutes)
DEFAULT_TIMEOUT=300
