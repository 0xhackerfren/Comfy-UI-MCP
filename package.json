{
  "name": "comfyui-mcp-server",
  "version": "2.1.0",
  "description": "A comprehensive MCP server for full programmatic access to ComfyUI - supports image, audio, and video generation with pipeline orchestration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "comfyui-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "author": "0xhackerfren",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xhackerfren/Comfy-UI-MCP.git"
  },
  "homepage": "https://github.com/0xhackerfren/Comfy-UI-MCP",
  "bugs": {
    "url": "https://github.com/0xhackerfren/Comfy-UI-MCP/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "comfyui",
    "stable-diffusion",
    "image-generation",
    "ai",
    "workflow",
    "flux",
    "sdxl",
    "video-generation",
    "audio-generation"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.5.0",
    "vitest": "^3.1.0"
  }
}
